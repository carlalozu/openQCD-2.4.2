
################################################################################
#
# HMC master-field simulation of the SU(3) YM theory with Wilson plaquette
# action, periodic boundary conditions and parallel configuration I/O.
# Parameters tuned for simulations of 8x8^3 lattices.
#
# The parameter file assumes that the specified block size in the section
# "Configurations" is compatible with the lattice sizes defined in
# include/global.h (for further information see main/README.global and
# main/README.io).
#
################################################################################

[Run name]
name         hmc_scale_clang

[Log and data directories]
log_dir      ../../data/ym1/log
dat_dir      ../../data/ym1/dat

[Configurations]
types        b
block_dir    ../../data/ym1/blk
bs 36 36 32 16
nio_nodes    1
nio_streams  1

[Random number generator]
level        0
seed         1297

[Lattice parameters]
beta         6.56185
c0           1.0

[Boundary conditions]
type         3

[Trajectory length]
tau          2.0

[MD trajectories]
nth          0
ntr          40
dtr_log      10
dtr_ms       10
dtr_cnfg     20

[MD integrator]
integrator   OMF4
nstep        16
