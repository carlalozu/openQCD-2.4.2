################################################################################
#
# Makefile to compile and link C programs with MPI subroutines
#
# Version valid for Linux machines with MPICH
#
# "make" compiles and links the specified main programs and modules,
# using the specified libraries (if any), and produces the executables
#
# "make clean" removes all files generated by "make"
#
# Dependencies on included files are automatically taken care of
#
################################################################################

all: rmxeq mkdep mkxeq
.PHONY: all


# main programs and modules to be compiled

MAIN = check1 check2 check3 check4 check5 check6 time1

DEVFCTS = dutils gtrans

FLAGS = flags lat_parms dfl_parms

LATTICE = bcnds geogen geometry uidx

RANDOM = ranlux ranlux_common ranlxs ranlxd gauss

SU3FCTS = su3prod su3ren cm3x3 random_su3

UFLDS = bstap plaq_sum shift udcom uflds uinit

UTILS = endian error mutils qsum utils wspace

MODULES = $(DEVFCTS) $(FLAGS) $(LATTICE) $(RANDOM) $(UFLDS) \
          $(SU3FCTS) $(UTILS)


# Logging option (-mpilog or -mpitrace or -mpianim)

LOGOPTION =


# search path for modules

MDIR = ../../modules

VPATH = .:$(MDIR)/devfcts:$(MDIR)/flags:$(MDIR)/lattice:$(MDIR)/random:\
          $(MDIR)/uflds:$(MDIR)/su3fcts:$(MDIR)/utils


# additional include directories

INCPATH = $(MPI_INCLUDE) ../../include


# additional libraries

LIBS = m

LIBPATH = $(MPI_HOME)/lib /opt/cray/pe/cce/12.0.3/cce-clang/x86_64/lib


# scheduling and optimization options

CFLAGS = -pedantic -fstrict-aliasing -fopenmp -fopenmp-targets=nvptx64-nvidia-cuda -performance-report -Wall \
         -Wno-long-long -Wstrict-prototypes \
         -O -mfpmath=sse -mno-avx -DAVX -DFMA3 -DPM

LFLAGS = -fopenmp

#CFLAGS = -mp=gpu -Minfo=mp,accel


#LFLAGS = #-mp=gpu -Minfo=mp,accel

############################## do not change ###################################

SHELL=/bin/bash
CC=cc

CLINKER=$(CC)

PGMS= $(MAIN) $(MODULES)

-include $(addsuffix .d,$(PGMS))


# rule to make dependencies

$(addsuffix .d,$(PGMS)): %.d: %.c Makefile_GPU_prof
	@ $(GCC) -ansi $< -MM $(addprefix -I,$(INCPATH)) -o $@


# rule to compile source programs

$(addsuffix .o,$(PGMS)): %.o: %.c Makefile_GPU_prof
	$(CC) $< -c $(CFLAGS) $(LOGOPTION) $(addprefix -I,$(INCPATH))


# rule to link object files

$(MAIN): %: %.o $(addsuffix .o,$(MODULES)) Makefile_GPU_prof
	$(CLINKER) $< $(addsuffix .o,$(MODULES)) $(LFLAGS) $(LOGOPTION) \
        $(addprefix -L,$(LIBPATH)) $(addprefix -l,$(LIBS)) -o $@


# produce executables

mkxeq: $(MAIN)


# remove old executables

rmxeq:
	@ -rm -f $(MAIN); \
        echo "delete old executables"


# make dependencies

mkdep:  $(addsuffix .d,$(PGMS))
	@ echo "generate tables of dependencies"


# clean directory

clean:
	@ -rm -rf *.d *.o *.alog *.clog *.slog $(MAIN)
.PHONY: clean

################################################################################
